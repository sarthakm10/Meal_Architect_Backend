meta {
  name: Search Ingredients By Category
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/ingredients/search
  body: none
  auth: none
}

params:query {
  category: {{ingredientCategory}}
}

headers {
  ~Authorization: Bearer {{token}}
}

vars:pre-request {
  baseUrl: http://localhost:8080
}
